VENV_DIR := .venv
PYTHON := $(VENV_DIR)/bin/python
PIP := $(VENV_DIR)/bin/pip

.PHONY: install
install:
	python3 -m venv $(VENV_DIR)
	$(PIP) install --upgrade pip
	$(PIP) install -e .{% if include_ruff or include_mypy or include_pytest %}[dev]{% endif %}

.PHONY: lint
lint:
{% if include_ruff -%}
	$(PYTHON) -m ruff check .
{% else -%}
	@echo "Ruff is not enabled for the {{ preset_name }} preset."
{% endif %}

.PHONY: format
format:
{% if include_ruff -%}
	$(PYTHON) -m ruff format .
{% else -%}
	@echo "Ruff is not enabled for the {{ preset_name }} preset."
{% endif %}

.PHONY: typecheck
typecheck:
{% if include_mypy -%}
	$(PYTHON) -m mypy .
{% else -%}
	@echo "mypy is not enabled for the {{ preset_name }} preset."
{% endif %}

.PHONY: test
test:
{% if include_pytest -%}
	$(PYTHON) -m pytest
{% else -%}
	@echo "pytest is not enabled for the {{ preset_name }} preset."
{% endif %}

.PHONY: check-all
check-all:
{% if include_ruff -%}
	$(PYTHON) -m ruff check .
{% endif -%}
{% if include_mypy -%}
	$(PYTHON) -m mypy .
{% endif -%}
{% if include_pytest -%}
	$(PYTHON) -m pytest
{% endif -%}
{% if not include_ruff and not include_mypy and not include_pytest -%}
	@echo "No extra quality tooling is enabled for the {{ preset_name }} preset."
{% endif %}
